doctype html
html(lang="ja")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")

    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      integrity="sha256-fx038NkLY4U1TCrBDiu5FWPEa9eiZu01EiLryshJbCo="
      crossorigin="anonymous")
    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css")

    link(rel="preconnect"
      href="https://fonts.gstatic.com" crossorigin)
    link(rel="preconnect"
      href="https://fonts.googleapis.com")
    link(rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=M+PLUS+Rounded+1c:wght@100;300;400;500;700;800;900&family=Noto+Sans+JP:wght@100..900&family=Roboto:ital,wght@0,100..900;1,100..900&family=SN+Pro:ital,wght@0,200..900;1,200..900&display=swap")

    link(rel="stylesheet"
      href="style.css")
    title カウントダウン・タイマー
  body.bg-light.py-4
    div.container
      header.mb-4.text-center
        h1.display-5.w800.text-primary.d-flex.align-items-center.justify-content-center.lh-1
          img.me-2(src="/icon.png" alt="ロゴ" style="width: 1em; height: 1em; object-fit: contain;")
          | カウントダウン・タイマー

      section.mb-5
        if pinnedEvent
          div.card.border-primary
            div.card-header.bg-primary.text-white.d-flex.align-items-center
              i.bi.bi-pin-angle-fill.fs-4.me-2
              h2.h5.mb-0 ピン留めされたイベント
            div.card-body.text-center.py-4
              h3.card-title.h2.fw-bold.mb-3 #{pinnedEvent.title} まで
              div.mb-3
                p.countdown-display.w900.text-danger.mb-0(data-date=pinnedEvent.date) 残り時間を計算中...
              p.card-text.text-muted.mb-0
                i.bi.bi-calendar3.me-1
                | #{pinnedEvent.formattedDate}
        else
          div.card.border-secondary.bg-white
            div.card-body.text-center.py-4
              i.bi.bi-pin-angle.fs-1.text-muted.mb-2
              h2.h5.card-title.text-secondary ピン留めされたイベントはありません
              p.card-text.text-muted.small.mb-0 下のリストで、トップに固定表示したいイベントを設定してください

      section
        h2.h4.mb-4.pb-2.border-bottom
          i.bi.bi-list-ul.me-2
          | リスト

        div.row.g-4.row-cols-1.row-cols-lg-3
          each eventItem, index in eventList
            - const slotNumber = index + 1
            div.col
              div.card.h-100
                div.card-header.bg-dark.text-white.d-flex.justify-content-between.align-items-center
                  span.fw-bold イベント#{slotNumber}

                  if eventItem && (pinnedEvent === eventItem)
                    span.badge.bg-primary.d-flex.align-items-center.gap-1.py-2.px-3
                      i.bi.bi-pin-angle-fill
                      | ピン留め中
                  else if eventItem
                    form(method="POST" action="/events/pin" class="m-0")
                      input(type="hidden" name="slot" value=slotNumber)
                      input(type="hidden" name="oneTimeToken" value=oneTimeToken)
                      button(type="submit" class="btn btn-outline-light btn-sm d-flex align-items-center gap-1 py-1 px-2")
                        i.bi.bi-pin-angle
                        | ピン留め

                div.card-body.d-flex.flex-column.justify-content-between
                  if eventItem
                    div.text-center.my-3
                      h4.card-title.h5.w700.mb-2 #{eventItem.title} まで
                      div.my-3
                        p.countdown-display.w800.text-warning.mb-0(data-date=eventItem.date) 残り時間を計算中…
                      p.card-text.text-muted.small.mb-0
                        i.bi.bi-calendar3.me-1
                        | #{eventItem.formattedDate}
                      
                    form(method="POST" action="/events/delete" class="mt-3")
                      input(type="hidden" name="slot" value=slotNumber)
                      input(type="hidden" name="oneTimeToken" value=oneTimeToken)
                      button(type="submit" class="btn btn-outline-danger btn-sm w-100 d-flex align-items-center justify-content-center gap-1")
                        i.bi.bi-trash
                        | このイベントを削除する

                  else
                    form(method="POST" action="/events" class="d-flex flex-column h-100 justify-content-between")
                      input(type="hidden" name="slot" value=slotNumber)
                      input(type="hidden" name="oneTimeToken" value=oneTimeToken)

                      div.my-2
                        h4.h6.text-secondary.text-center.mb-3 新しいイベントを設定してください
                        div.mb-3
                          label.form-label.small.fw-bold タイトル
                          input(type="text" name="title" required maxlength="30" placeholder="30文字まで入力できます" class="form-control form-control-sm")
                        div.mb-3
                          label.form-label.small.fw-bold 日時
                          input(type="datetime-local" name="date" required class="form-control form-control-sm")
                      button(type="submit" class="btn btn-primary btn-sm w-100 d-flex align-items-center justify-content-center gap-1 mt-2")
                        i.bi.bi-wrench
                        | このイベントを設定する
      footer.mt-5.py-4.border-top.text-center
        p.text-muted.small.mb-0
          | &copy; 2026 yuitoko

  script(src="/countdown-timer.js")